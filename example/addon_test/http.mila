// Test HTML Addon for MiLa

http.init();
var header = [@"User-Agent" = "MiLa Script"];
println("Waiting for response.");
var data = http.get("http://eu.httpbin.org/anything?id=90", "this is the body", header);
var res = json.loads(data:body);
if (res) println(json.dumps(res));
else println(data:body);
http.cleanup();

