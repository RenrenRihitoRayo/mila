var names = list(
	"Darren",
	"Yeliah",
	"Ezridith",
	"HE1"
);

println(names);

foreach name : names {
	println(name);
}

list.append(names, "Test");
list.pop(names, 0);

foreach name : names {
	println(name);
}

forget names;

var names = array.from(
	"Darren",
	"Yeliah",
	"Ezridith",
	"HE1"
);

println(names);

foreach name : names {
	println(name);
}

forget names;

