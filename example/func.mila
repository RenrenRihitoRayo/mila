
var default_name = "[user]";

var counter = 0;

fn count() {
    set counter += 1;
    return counter;
}

// New update now removes the eval once on definition
fn greet(name=default_name, additional=name) {
    println("Hello " + name + "! " + additional);
}

greet("Ren"); // additional is Ren
greet(); // additional is [user]

object what {
    fn get_test(self) {
        return self["test"];
    }
}

object test with what {}

println(test);