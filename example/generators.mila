
// Generators using threads.

var gen = thread.make(fn(gen):[thread.yield]{
    var n = 0;
    while (n<1000000) {set n+=1;thread.yield(gen,n);}
});

// Implicitly calls thread.next
var time = get_time();
foreach yield n : gen {
    println(n);
}
var gen_end = get_time() - time;
input();
var time = get_time();
foreach n : range(1000000) {
    println(n);
}
var end = get_time() - time;
println("Generator Time: "+gen_end+"s");
println("Iteration Time: "+end+"s");