
var list_lit = [90, 80, 70];

var dict_lit = [@
	"name" = "Darren",
	"age" = 16,
	"height" = 1.56,
	"fav number" = 0x45,
	"fav color" = 15019525u,
	"nerdiness" = 80%
];

println(list_lit, dict_lit);

var oop = [@
	"name" = "Alex",
	"greet" = fn(self) {
		println("Hello, I am " + self["name"] + "!");
	}
]

oop:greet();