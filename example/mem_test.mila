var a = dict(
	"key0", "value0",
	"key1", "value1"
);

println("normal output:", a);

foreach item : range(5143) {
	set a[item] = item;
}

println("compacted output:", a);

var a = list("value");

println("normal output:", a);

foreach item : range(5143) {
	list.append(a, item);
}

println("compacted output:", a);

var a = array.from("value");
println("normal output:", a);

var a = array(5143);
println("normal output:", a);