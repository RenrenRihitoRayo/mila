var start_time = get_time();
var a = list();
var fact = fn(n) {
    var s = 1u;
    while (n > 1)
    {
        set s *= n;
        set n -= 1u;
    }
    return s;
}
foreach item : range(1, 2001) {
    list.append(a, fact(cast.i2u(item)));
}
var end_time = get_time() - start_time;

println("Time: " + end_time + "s");
println(a[1999]);