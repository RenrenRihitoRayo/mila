
var out_item = 0;
var th = thread.make(fn(id):[out_item, println, time_sleep, thread.check_cancel, range, copy]{
	println("Running as thread #"+id);
	foreach item : range(4) {
		thread.check_cancel(id);
		println("Item " + item);
		sync out_item = copy(item);
		time_sleep(1);
	}
	println("Done");
}, fn(id, reason):[println, out_item] {
	println("Stopped at " + out_item);
	println("Reason for halt of execution: "+reason);
});
//thread.set_daemon(th);
thread.join(th);